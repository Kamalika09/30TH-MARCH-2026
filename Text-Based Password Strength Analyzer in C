#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char password[100];
    int length, i;
    int hasUpper = 0, hasLower = 0, hasDigit = 0, hasSpecial = 0;
    int score = 0;

    printf("Enter your password: ");
    scanf("%s", password);

    length = strlen(password);

    // Check length
    if (length >= 8)
        score++;
    
    // Analyze characters
    for (i = 0; i < length; i++) {
        if (isupper(password[i]))
            hasUpper = 1;
        else if (islower(password[i]))
            hasLower = 1;
        else if (isdigit(password[i]))
            hasDigit = 1;
        else
            hasSpecial = 1;
    }

    score += hasUpper + hasLower + hasDigit + hasSpecial;

    printf("\nPassword Analysis:\n");
    printf("Length: %d\n", length);
    printf("Uppercase: %s\n", hasUpper ? "Yes" : "No");
    printf("Lowercase: %s\n", hasLower ? "Yes" : "No");
    printf("Digits: %s\n", hasDigit ? "Yes" : "No");
    printf("Special Characters: %s\n", hasSpecial ? "Yes" : "No");

    // Strength result
    printf("\nStrength: ");
    if (score <= 2)
        printf("Weak \n");
    else if (score <= 4)
        printf("Medium \n");
    else
        printf("Strong \n");

    // Suggestions
    printf("\nSuggestions:\n");
    if (!hasUpper) printf("- Add uppercase letters\n");
    if (!hasLower) printf("- Add lowercase letters\n");
    if (!hasDigit) printf("- Add numbers\n");
    if (!hasSpecial) printf("- Add special characters\n");
    if (length < 8) printf("- Use at least 8 characters\n");

    return 0;
}
